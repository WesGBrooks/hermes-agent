# Hermes on Railway — variable *names* to configure in the Railway dashboard.
#
# Usage:
#   1. Railway → your service → Variables → RAW Editor (or add one-by-one).
#   2. Paste the lines you need; fill values on the right (never commit real secrets).
#   3. Redeploy. Values persist across deploys; rotate by editing variables in Railway.
#
# Hermes reads process environment first, then HERMES_HOME/.env (see get_env_value() in
# hermes_cli/config.py), so Railway Variables override the bootstrapped /opt/data/.env.
#
# ---------------------------------------------------------------------------
# LLM (set at least one provider key your config.yaml model.* uses)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Discord
# ---------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# DISCORD_ALLOW_ALL_USERS=false
# DISCORD_HOME_CHANNEL=
# DISCORD_HOME_CHANNEL_NAME=
# DISCORD_ALLOWED_CHANNELS=
# DISCORD_REQUIRE_MENTION=false

# ---------------------------------------------------------------------------
# Telegram (webhook URL is typical on Railway — set public URL + path your gateway uses)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_HOME_CHANNEL=
# TELEGRAM_HOME_CHANNEL_NAME=

# ---------------------------------------------------------------------------
# WhatsApp (Baileys bridge — pair once via `hermes whatsapp` over Railway SSH if needed)
# ---------------------------------------------------------------------------
WHATSAPP_ENABLED=false
# WHATSAPP_MODE=bot
# WHATSAPP_ALLOWED_USERS=
# WHATSAPP_ALLOW_ALL_USERS=false
# WHATSAPP_DM_POLICY=
# WHATSAPP_GROUP_POLICY=

# ---------------------------------------------------------------------------
# Slack (Socket Mode needs both tokens)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=

# ---------------------------------------------------------------------------
# Voice / STT (optional)
# ---------------------------------------------------------------------------
# VOICE_TOOLS_OPENAI_KEY=
# GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Gateway-wide access (optional — prefer per-platform allowlists)
# ---------------------------------------------------------------------------
# GATEWAY_ALLOW_ALL_USERS=false

# ---------------------------------------------------------------------------
# Non-interactive OAuth bootstrap (optional — consumed once on first boot; see docker/entrypoint.sh)
# ---------------------------------------------------------------------------
# HERMES_AUTH_JSON_BOOTSTRAP=

# ---------------------------------------------------------------------------
# Common tool APIs (uncomment what you use)
# ---------------------------------------------------------------------------
# TAVILY_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# BRAVE_SEARCH_API_KEY=
# GITHUB_TOKEN=
